          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EventTypeId">
          <DataField>EventTypeId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="IsMng">
          <DataField>IsMng</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="Time">
          <DataField>Time</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Cnt">
          <DataField>Cnt</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Avg">
          <DataField>Avg</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Min">
          <DataField>Min</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Max">
          <DataField>Max</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Stdev">
          <DataField>Stdev</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="Stdevp">
          <DataField>Stdevp</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
