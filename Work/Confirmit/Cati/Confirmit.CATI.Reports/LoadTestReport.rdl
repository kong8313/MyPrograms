    <DataSet Name="InterviewerHistory">
      <Query>
        <DataSourceName>db</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ReportID">
            <Value>=Parameters!ReportID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select * from Histories WHERE ReportID = @ReportID AND IsMng=0</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ReportID">
          <DataField>ReportID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="EventTypeName">
