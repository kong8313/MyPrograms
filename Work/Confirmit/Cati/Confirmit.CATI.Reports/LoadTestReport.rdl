  <DataSets>
    <DataSet Name="ReportList">
      <Query>
        <DataSourceName>db</DataSourceName>
        <CommandText>select ID, CAST( ID AS NVARCHAR(MAX)) + ' ' +  ISNULL(CAST( StartTime as NVARCHAR(MAX)) + '-' + CAST( FinishTime AS NVARCHAR(MAX)) + ' CID(' + CAST( CompanyId AS NVARCHAR(MAX))+ ') - ' + ISNULL(Description,'')   , 'Unknown' ) as Name FROM Reports ORDER BY ID</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField>ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DefaultReportId">
      <Query>
        <DataSourceName>db</DataSourceName>
        <CommandText>select Max(ID) from Reports</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField />
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
