<?xml version="1.0" encoding="utf-8"?>
<!-- For more information on using web.config transformation visit http://go.microsoft.com/fwlink/?LinkId=125889 -->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
    <system.web>
        <compilation xdt:Transform="RemoveAttributes(debug)" />
        <sessionState mode="Custom" cookieName="ConfirmitCati_SessionId" cookieless="false" timeout="120" customProvider="RedisSessionStateProvider" xdt:Transform="Replace">
            <providers>
                <clear />
                <add type="Microsoft.Web.Redis.RedisSessionStateProvider"
                     name="RedisSessionStateProvider"
                     connectionString="redis-announce-0:6379,redis-announce-1:6379,redis-announce-2:6379" />
            </providers>
        </sessionState>
    </system.web>
    <appSettings xdt:Transform="InsertIfMissing">
        <add key="Logging.Level" value="Info" xdt:Transform="InsertIfMissing" xdt:Locator="Match(key)"/>
        <add key="Logging.Level" value="Info" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
        <add key="ConfirmitKeepSessionAspxUrl" value="/confirm/authoring/KeepSession.aspx" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
        <add key="DebugMode" value="false" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
    </appSettings>
    <secureAppSettings>
        <add key="CustomGrant.ClientSecret" xdt:Transform="Remove" xdt:Locator="Match(key)" />
        <add key="Introspection.ClientSecret" xdt:Transform="Remove" xdt:Locator="Match(key)" />
        <add key="TrustedSubsystem.ClientSecret" xdt:Transform="Remove" xdt:Locator="Match(key)" />
        <add key="ServiceClient.ClientSecret" xdt:Transform="Remove" xdt:Locator="Match(key)" />
    </secureAppSettings>

    <Telerik.Reporting xdt:Transform="Replace">
		<extensions>
			<render>
				<extension name="PDF" visible="false" />
			</render>
		</extensions>
        <Cache provider="ADO.NET">
            <Providers>
                <Provider name="ADO.NET">
                    <Parameters>
                        <Parameter name="ProviderName" value="System.Data.SqlClient" />
                        <Parameter name="ConnectionString" value="TelerikReportingCacheConnectionString" />
                    </Parameters>
                </Provider>
            </Providers>
        </Cache>
    </Telerik.Reporting>
    
    <infragistics.web xdt:Transform="SetAttributes" styleSetPath="~/ig_res_$NugetPackageVersion$" />
</configuration>