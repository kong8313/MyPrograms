    </system.web>
  </location>
  <location path="Reports">
    <system.web>
      <authorization>
        <allow roles="Reports" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="Reports/ProductivityReport.aspx">
    <system.web>
      <authorization>
        <allow roles="ProductivityReport, Reports" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="ActivityViews">
    <system.web>
      <httpRuntime executionTimeout="30" />
      <authorization>
        <allow roles="ActvivityViews" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="Records">
    <system.web>
      <authorization>
        <allow roles="RecordedInterviews" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="Messaging">
