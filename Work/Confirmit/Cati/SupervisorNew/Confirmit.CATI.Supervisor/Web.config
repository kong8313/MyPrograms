  <!--Section for work with Supervisor WCF service.
      It is used inside that assembly to redirect some of method calls from IIS to backend service.-->
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="InternalService_BasicHttpBinding" closeTimeout="00:10:00" openTimeout="00:10:00" sendTimeout="00:10:00" maxReceivedMessageSize="2147483647">
          <readerQuotas maxStringContentLength="5242880" maxArrayLength="2147483647" />
        </binding>
      </basicHttpBinding>
    </bindings>
    <client>
      <endpoint name="SupervisorServiceEndpoint" address="http://localhost/SupervisorMultimodeInstance" binding="basicHttpBinding" bindingConfiguration="InternalService_BasicHttpBinding" contract="Confirmit.CATI.Core.SupervisorService.ISupervisorService" />
    </client>
  </system.serviceModel>
  <Telerik.Reporting>
    <Cache provider="ADO.NET">
      <Providers>
        <Provider name="ADO.NET">
          <Parameters>
            <Parameter name="ProviderName" value="System.Data.SqlClient" />
            <Parameter name="ConnectionString" value="Data Source=localhost;Initial Catalog=ConfirmitCATIV15;User ID=sa;Password=firm;Connect Timeout=120" />
          </Parameters>
        </Provider>
      </Providers>
    </Cache>
  </Telerik.Reporting>
