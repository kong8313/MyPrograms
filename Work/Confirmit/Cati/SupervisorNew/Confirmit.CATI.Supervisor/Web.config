  </location>
  <location path="Resources/DbUpdateLog.aspx">
    <system.web>
      <authorization>
        <allow roles="Pros" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="Resources/DbUpdateLogProperties.aspx">
    <system.web>
      <authorization>
        <allow roles="Pros" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="Script">
