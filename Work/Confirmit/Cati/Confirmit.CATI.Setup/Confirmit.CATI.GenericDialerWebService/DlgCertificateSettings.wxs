<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <UI>
      <Dialog Id="DlgCertificateSettings" Width="370" Height="270" Title="!(loc.CertificateSettings_Title)">
        <Control Id="AuthorizationConfiguration" Type="CheckBox" Width="320" Height="12" X="15" Y="50" Property="USE_AUTHORIZATION" CheckBoxValue="1" Text="!(loc.CertificateSettingsAuthorizationCheckBox)" />
        <Control Type="Text" Id="authorizationKeyText" Width="154" Height="10" X="20" Y="68" Text="!(loc.CertificateSettingsAuthorizationKey)">
          <Condition Action="disable">USE_AUTHORIZATION~=""</Condition>
          <Condition Action="enable">USE_AUTHORIZATION~="1"</Condition>
        </Control>
        <Control Type="Edit" Id="authorizationKeyEdit" Width="175" Height="15" X="175" Y="65" Property="AUTHORIZATION_KEY">
          <Condition Action="disable">USE_AUTHORIZATION~=""</Condition>
          <Condition Action="enable">USE_AUTHORIZATION~="1"</Condition>
        </Control>
        <Control Id="BindingConfigurationText" Type="Text" Width="320" Height="12" X="15" Y="85" Text="!(loc.CertificateSettingsBindingText)" />
        <Control Id="BindingConfiguration" Type="RadioButtonGroup" X="20" Y="100" Width="154" Height="32" Property="BINDING_CONFIGURATION">
          <RadioButtonGroup Property="BINDING_CONFIGURATION">
            <RadioButton Value="http" X="0" Y="0" Width="240" Height="16" Text="!(loc.CertificateSettingsHttpBinding)" />
            <RadioButton Value="https" X="0" Y="15" Width="240" Height="16" Text="!(loc.CertificateSettingsHttpsBinding)" />
          </RadioButtonGroup>
        </Control>
        <Control Id="QuestionText" Type="Text" Width="238" Height="10" X="30" Y="133" Text="!(loc.CertificateSettingsQuestion)">
          <Condition Action="disable">BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Id="CertificateOption" Type="RadioButtonGroup" X="30" Y="145" Width="115" Height="44" Property="CERTIFICATE_TYPE">
          <RadioButtonGroup Property="CERTIFICATE_TYPE">
            <RadioButton Value="Test" X="0" Y="0" Width="260" Height="16" Text="!(loc.CertificateSettingsTest)" />
            <RadioButton Value="Real" X="0" Y="30" Width="260" Height="16" Text="!(loc.CertificateSettingsReal)" />
          </RadioButtonGroup>
          <Condition Action="disable">BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Type="Text" Id="testCertificateNameText" Width="87" Height="10" X="41" Y="162" Text="!(loc.CertificateSettingsTestName)">
          <Condition Action="disable">CERTIFICATE_TYPE~="Real" OR BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">CERTIFICATE_TYPE~="Test" AND BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Type="Edit" Id="testCertificateNameEdit" Width="130" Height="15" X="140" Y="160" Property="TEST_CERTIFICATE_NAME">
          <Condition Action="disable">CERTIFICATE_TYPE~="Real" OR BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">CERTIFICATE_TYPE~="Test" AND BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Type="PushButton" Id="GetFullDomainName" Width="70" Height="17" X="280" Y="159" Text="!(loc.CertificateSettingsGetFullDomainNameButton)">
          <Publish Event="DoAction" Value="GetFullDomainNameCustomAction" Order="1">
            CERTIFICATE_TYPE~="Test"
          </Publish>
          <Publish Property="TEST_CERTIFICATE_NAME" Value="[TEST_CERTIFICATE_NAME]" Order="2">1</Publish>
          <Condition Action="disable">CERTIFICATE_TYPE~="Real" OR BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">CERTIFICATE_TYPE~="Test" AND BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Id="certificatePathText" Type="Text" X="40" Y="193" Width="94" Height="10" Text="!(loc.CertificateSettingsCertificatePath)">
          <Condition Action="disable">CERTIFICATE_TYPE~="Test" OR BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">CERTIFICATE_TYPE~="Real" AND BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Id="certificatePathEdit" Type="Edit" X="140" Y="190" Width="130" Height="15" Property="CERTIFICATE_PATH">
          <Condition Action="disable">CERTIFICATE_TYPE~="Test" OR BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">CERTIFICATE_TYPE~="Real" AND BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Type="PushButton" Id="SelectPathToCertificate" Width="70" Height="17" X="280" Y="189" Text="!(loc.CertificateSettingsSelectCertificateButton)">
          <Publish Event="DoAction" Value="SelectPathToCertificateCustomAction" Order="1">1</Publish>
          <Publish Property="CERTIFICATE_PATH" Value="[CERTIFICATE_PATH]" Order="2">1</Publish>
          <Condition Action="disable">CERTIFICATE_TYPE~="Test" OR BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">CERTIFICATE_TYPE~="Real" AND BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Type="Text" Id="certificatePasswordText" Width="88" Height="10" X="40" Y="213" Text="!(loc.CertificateSettingsCertificatePassword)">
          <Condition Action="disable">CERTIFICATE_TYPE~="Test" OR BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">CERTIFICATE_TYPE~="Real" AND BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Type="Edit" Id="certificatePasswordEdit" Width="130" Height="15" X="140" Y="210" Property="CERTIFICATE_PASSWORD" Password="yes">
          <Condition Action="disable">CERTIFICATE_TYPE~="Test" OR BINDING_CONFIGURATION~="http"</Condition>
          <Condition Action="enable">CERTIFICATE_TYPE~="Real" AND BINDING_CONFIGURATION~="https"</Condition>
        </Control>
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="DoAction" Value="ValidateCertificateNamesAvailabilityCustomAction" Order="1">
            BINDING_CONFIGURATION~="https"
          </Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.CertificateSettingsBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="2" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.CertificateSettingsDescription)" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.CertificateSettings_Title)" />
      </Dialog>
    </UI>
  </Fragment>
</Wix>