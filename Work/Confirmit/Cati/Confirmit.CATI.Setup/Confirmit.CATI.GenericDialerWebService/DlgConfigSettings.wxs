<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <UI>
      <Dialog Id="DlgConfigSettings" Width="370" Height="270" Title="!(loc.ConfigSettings_Title)">
        <?if $(var.GType)="simulator" or $(var.GType)="simulator_ltu" ?>
          <Control Id="MaxConnectionText" Type="Text" Width="160" Height="17" X="20" Y="102" Text="!(loc.ConfigSettingsMaxConnectionCount)" />
          <Control Id="MaxConnectionEdit" Type="Edit" Width="170" Height="15" X="190" Y="100" Property="MAX_CONNECTION_COUNT" />
          <Control Id="DialerIdText" Type="Text" Width="160" Height="20" X="20" Y="152" Text="!(loc.ConfigSettingsDialerId)" />
          <Control Id="DialerIdEdit" Type="Edit" Width="170" Height="15" X="190" Y="150" Property="DIALER_ID" />
        <?endif ?>

        <?if $(var.GType)="no" ?>
          <Control Id="MaxConnectionText" Type="Text" Width="160" Height="17" X="20" Y="67" Text="!(loc.ConfigSettingsMaxConnectionCount)" />
          <Control Id="MaxConnectionEdit" Type="Edit" Width="170" Height="15" X="190" Y="65" Property="MAX_CONNECTION_COUNT" />
          <Control Id="DialerIdText" Type="Text" Width="160" Height="20" X="20" Y="112" Text="!(loc.ConfigSettingsDialerId)" />
          <Control Id="DialerIdEdit" Type="Edit" Width="170" Height="15" X="190" Y="110" Property="DIALER_ID" />
          <Control Id="DialerTypeText" Type="Text" Width="330" Height="17" X="20" Y="152" Text="!(loc.ConfigSettingsChoiceDialerType)" />
          <Control Id="DialerTypeOption" Type="RadioButtonGroup" X="30" Y="170" Width="317" Height="44" Property="GENERIC_DIALER_TYPE">
            <RadioButtonGroup Property="GENERIC_DIALER_TYPE">
              <RadioButton Value="NotDefined" X="0" Y="0" Width="320" Height="16" Text="!(loc.ConfigSettingsNotDefined)" />
              <RadioButton Value="InVade" X="0" Y="15" Width="320" Height="16" Text="!(loc.ConfigSettingsInVade)" />
              <RadioButton Value="Sytel" X="0" Y="30" Width="320" Height="16" Text="!(loc.ConfigSettingsSytel)" />
            </RadioButtonGroup>
          </Control>
        <?endif ?>

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" >
          <Publish Event="DoAction" Value="ValidateConfigSettingsForGenericInstallationCustomAction" Order="1">1</Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.ConfigSettingsBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="2" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.ConfigSettingsDescription)" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="297" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.ConfigSettings_Title)" />
      </Dialog>
    </UI>
  </Fragment>
</Wix>