<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Fragment>
        <UI>
            <Dialog Id="DlgLoggingSettings" Width="370" Height="270" Title="!(loc.LoggingSettings_Title)">
                <Control Id="QuestionText" Type="Text" Width="185" Height="10" X="40" Y="64" Text="!(loc.LoggingSettingsQuestion)" />
                <Control Id="LogToFile" Type="CheckBox" Width="196" Height="12" X="56" Y="86" Property="IS_FILE_LOGGING_ENABLED" CheckBoxValue="1" Text="!(loc.LoggingSettingsLogToFile)" />
                <Control Type="Text" Id="TextFileFormat" Width="84" Height="10" X="71" Y="107" Text="!(loc.LoggingSettingsFormatFileName)">
                    <Condition Action="enable">IS_FILE_LOGGING_ENABLED~="1"</Condition>
                    <Condition Action="disable">IS_FILE_LOGGING_ENABLED~=""</Condition>
                </Control>
                <Control Type="Edit" Id="EditFormatFileName" Width="140" Height="15" X="170" Y="105" Property="LOG_FILE_NAME">
                    <Condition Action="enable">IS_FILE_LOGGING_ENABLED~="1"</Condition>
                    <Condition Action="disable">IS_FILE_LOGGING_ENABLED~=""</Condition>
                </Control>
                <Control Type="Text" Id="TextFilePath" Width="71" Height="10" X="71" Y="127" Text="!(loc.LoggingSettingsFilePath)">
                    <Condition Action="enable">IS_FILE_LOGGING_ENABLED~="1"</Condition>
                    <Condition Action="disable">IS_FILE_LOGGING_ENABLED~=""</Condition>
                </Control>
                <Control Type="Edit" Id="EditFilePath" Width="140" Height="15" X="170" Y="125" Property="LOG_FILE_PATH">
                    <Condition Action="enable">IS_FILE_LOGGING_ENABLED~="1"</Condition>
                    <Condition Action="disable">IS_FILE_LOGGING_ENABLED~=""</Condition>
                </Control>
                <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
                <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)">
                    <Publish Event="DoAction" Value="VerifyLoggingSettingsCustomAction" Order="1">1</Publish>
                </Control>
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
                    <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
                </Control>
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.LoggingSettingsBannerBitmap)" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
                <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="2" />
                <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.LoggingSettingsDescription)" />
                <Control Id="Title" Type="Text" X="15" Y="6" Width="250" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.LoggingSettings_Title)" />
            </Dialog>
        </UI>
    </Fragment>
</Wix>