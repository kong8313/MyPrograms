<?xml  version="1.0"  encoding="UTF-8"?>
<Wix  xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Fragment>
        <UI  Id="WixUI">
            <TextStyle  Id="WixUI_Font_Normal"  FaceName="Tahoma"  Size="8"  />
            <TextStyle  Id="WixUI_Font_Bigger"  FaceName="Tahoma"  Size="12"  />
            <TextStyle  Id="WixUI_Font_Title"  FaceName="Tahoma"  Size="9"  Bold="yes"  />

            <Property  Id="DefaultUIFont"  Value="WixUI_Font_Normal"  />
            <Property  Id="WixUI_Mode"  Value="Mondo"  />

            <DialogRef  Id="ErrorDlg"  />
            <DialogRef  Id="FatalError"  />
            <DialogRef  Id="FilesInUse"  />
            <DialogRef  Id="MsiRMFilesInUse"  />
            <DialogRef  Id="PrepareDlg"  />
            <DialogRef  Id="ProgressDlg"  />
            <DialogRef  Id="ResumeDlg"  />
            <DialogRef  Id="UserExit"  />

            <Publish  Dialog="ExitDialog"  Control="Finish"  Event="EndDialog"  Value="Return"  Order="999">1</Publish>

            <Publish  Dialog="WelcomeDlg"  Control="Next"  Event="NewDialog"  Value="CustomizeDlg" Order="1">1</Publish>

            <!--<Publish  Dialog="LicenseAgreementDlg"  Control="Back"  Event="NewDialog"  Value="WelcomeDlg">1</Publish>
            <Publish  Dialog="LicenseAgreementDlg"  Control="Next"  Event="NewDialog"  Value="CustomizeDlg">1</Publish>-->


            <Publish  Dialog="CustomizeDlg"  Control="Back"  Event="NewDialog"  Value="MaintenanceTypeDlg"  Order="1">
                WixUI_InstallMode  =  "Change"
            </Publish>
            <Publish  Dialog="CustomizeDlg"  Control="Back"  Event="NewDialog"  Value="WelcomeDlg"  Order="2">1</Publish>
            <Publish  Dialog="CustomizeDlg"  Control="Next"  Event="NewDialog"  Value="DlgIISSettings"  Order="3" />


            <Publish  Dialog="DlgIISSettings"  Control="Back"  Event="NewDialog"  Value="CustomizeDlg"  Order="1">1</Publish>
            <Publish  Dialog="DlgIISSettings"  Control="Next"  Event="NewDialog"  Value="DlgConfigSettings"  Order="2"  >1</Publish>


            <Publish  Dialog="DlgConfigSettings"  Control="Back"  Event="NewDialog"  Value="DlgIISSettings"  Order="1">1</Publish>
            <Publish  Dialog="DlgConfigSettings"  Control="Next"  Event="NewDialog"  Value="DlgThreadingParams"  Order="2">1</Publish>


            <Publish  Dialog="DlgThreadingParams"  Control="Back"  Event="NewDialog"  Value="DlgConfigSettings"  Order="1">1</Publish>
            <Publish  Dialog="DlgThreadingParams"  Control="Next"  Event="NewDialog"  Value="DlgDumpSettings"  Order="2">1</Publish>

            
            <Publish  Dialog="DlgDumpSettings"  Control="Back"  Event="NewDialog"  Value="DlgThreadingParams"  Order="1">1</Publish>
            <Publish  Dialog="DlgDumpSettings"  Control="Next"  Event="NewDialog"  Value="DlgLoggingSettings"  Order="2">
                TEST_RESULT ~= "Success"
            </Publish>
            
            
            <Publish  Dialog="DlgLoggingSettings"  Control="Back"  Event="NewDialog"  Value="DlgDumpSettings"  Order="1">1</Publish>
            <Publish  Dialog="DlgLoggingSettings"  Control="Next"  Event="NewDialog"  Value="VerifyReadyDlg"  Order="2">
                TEST_RESULT ~= "Success"
            </Publish>

            
            <Publish  Dialog="VerifyReadyDlg"  Control="Back"  Event="NewDialog"  Value="DlgLoggingSettings" Order="1" >1</Publish>
            <Publish  Dialog="VerifyReadyDlg"  Control="Back"  Event="NewDialog"  Value="MaintenanceTypeDlg"  Order="3">
                WixUI_InstallMode  =  "Repair"  OR  WixUI_InstallMode  =  "Remove"
            </Publish>


            <Publish  Dialog="MaintenanceWelcomeDlg"  Control="Next"  Event="NewDialog"  Value="MaintenanceTypeDlg">1</Publish>


            <!--<Publish  Dialog="MaintenanceTypeDlg"  Control="ChangeButton"  Event="NewDialog"  Value="CustomizeDlg">1</Publish>
            <Publish  Dialog="MaintenanceTypeDlg"  Control="RepairButton"  Event="NewDialog"  Value="VerifyReadyDlg">1</Publish>-->
            <Publish  Dialog="MaintenanceTypeDlg"  Control="RemoveButton"  Event="NewDialog"  Value="VerifyReadyDlg">1</Publish>
            <Publish  Dialog="MaintenanceTypeDlg"  Control="Back"  Event="NewDialog"  Value="MaintenanceWelcomeDlg">1</Publish>
        </UI>

        <UIRef  Id="WixUI_Common"  />
    </Fragment>
</Wix>
