<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Fragment>
        <UI>
            <Dialog Id="DlgIISSettings" Width="370" Height="270" Title="!(loc.IISSettings_Title)">
                <Control Id="AppPoolText" Type="Text" Width="158" Height="17" X="34" Y="67" Text="!(loc.IISSettingsApplicationPoolName)" />
                <Control Id="AppPoolComboBox" Type="ComboBox" Width="167" Height="16" X="193" Y="65" Property="APP_POOL_NAME" />
                <Control Type="CheckBox" Id="IsSetRecyclingValueToZero" Width="159" Height="17" X="195" Y="85" Text="!(loc.IISSettingsRecyclingSettings)" Property="IS_SET_RECYCLING_VALUE_TO_ZERO" CheckBoxValue="1" />
                <Control Id="WebSiteText" Type="Text" Width="158" Height="17" X="34" Y="122" Text="!(loc.IISSettingsWebSiteName)" />
                <Control Id="WebSiteComboBox" Type="ComboBox" Width="167" Height="16" X="193" Y="120" Property="WEB_SITE_NAME" RightToLeft="yes" ComboList="yes"/>
                <Control Id="ConfirmitCATIServerAddressText" Type="Text" Width="158" Height="20" X="34" Y="162" Text="!(loc.IISSettingsConfirmitCATIServerAddress)" />
                <Control Id="ConfirmitCATIServerAddressEdit" Type="Edit" Width="167" Height="15" X="193" Y="160" Property="CATI_SERVER_ADDRESS" />
                <Control Id="AliasText" Type="Text" Width="158" Height="20" X="34" Y="202" Text="!(loc.IISSettingsAliasName)" />
                <Control Id="AliasEdit" Type="Edit" Width="167" Height="15" X="193" Y="200" Property="ALIAS_EDIT" Disabled="yes" />
                <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
                <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
                    <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
                </Control>
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.IISSettingsBannerBitmap)" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
                <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="2" />
                <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.IISSettingsDescription)" />
                <Control Id="Title" Type="Text" X="15" Y="6" Width="297" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.IISSettings_Title)" />
            </Dialog>
        </UI>
    </Fragment>
</Wix>