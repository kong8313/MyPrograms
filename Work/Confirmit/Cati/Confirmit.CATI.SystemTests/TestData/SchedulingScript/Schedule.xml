        <Body>function test31()
{
   var single_root = f('single_root').get();

   if(single_root === '1')
      f('single_root').setValue('2');
   else
      f('single_root').setValue('1');
}

function test32()
{
   var single_l1 = f('single_l1', '1').get();

   if(single_l1 === '1')
      f('single_l1', '1').setValue('2');
   else
      f('single_l1', '1').setValue('1');
}


function test33()
{
   var single_l2 = f('single_l1', '1', '1').get();

   if(single_l2 === '1')
      f('single_l2', '1', '1').setValue('2');
   else
      f('single_l2', '1', '1').setValue('1');
}

function test34()
{
   var multi_root = f('multi_root')['1'].get();

   if(multi_root === 'True')
      f('multi_root')['1'].setValue(false);
   else
      f('multi_root')['1'].setValue(true);
}

function test35()
{
   var multi_l1 = f('multi_l1', '1')['1'].get();

   if(multi_l1 === 'True')
      f('multi_l1', '1')['1'].setValue(false);
   else
      f('multi_l1', '1')['1'].setValue(true);
}

function test36()
{
   var multi_l2 = f('multi_l2', '1', '1')['1'].get();

   if(multi_l2 === 'True')
      f('multi_l2', '1', '1')['1'].setValue(false);
   else
      f('multi_l2', '1', '1')['1'].setValue(true);
}

function test37()
{
   var multi_root = f('multi_root')['3'].get();

   if(multi_root === 'True')
      f('multi_root')['3'].setValue(false);
   else
      f('multi_root')['3'].setValue(true);
}

function test38()
{
   var iter = GetRespondentValue('CallAttemptCount');
   if(isNaN(iter))
       iter = 0;
  
   iter = iter + 1;
   SetRespondentValue('CallAttemptCount', iter);

   f('single_l1', iter).setValue(iter % 3 + 1);
}
