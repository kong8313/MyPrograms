<ClassDiagram MajorVersion="1" MinorVersion="1">
  <Comment CommentText="ConsoleStateService has InterviewingStateBehaviour and InterviewingValidationBehaviour applied">
    <Position X="0.5" Y="2.396" Height="0.833" Width="1.981" />
  </Comment>
  <Comment CommentText="InterviewingValidationBehaviour gets current interviewer and task from InterviewingStateBehaviour and validates authentication key obtained from AuthorizationMessageHeaderBehaviour">
    <Position X="2.75" Y="4.844" Height="0.688" Width="2.481" />
  </Comment>
  <Comment CommentText="InterviewingStateBehaviour registers InterviewingStateExtension and has a static properties to get current interviewer and task cached in extension.">
    <Position X="2.802" Y="2.188" Height="0.865" Width="2.471" />
  </Comment>
  <Comment CommentText="InterviewingStateExtension gets interviewer login name from AuthorizationMessageHeaderBehavior, gets interviewer and task entities from DAL and caches them.">
    <Position X="5.5" Y="2.302" Height="0.865" Width="2.283" />
  </Comment>
  <Comment CommentText="AuthorizationMessageHeader is used from the console side to set login and key in the outgoing message headers. Also has static methods to extract login and key from the headers of incoming messages on the server side">
    <Position X="8" Y="1.812" Height="0.927" Width="2.283" />
  </Comment>
